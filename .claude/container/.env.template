# Agent container credentials template — secret references resolved at runtime by 1Password CLI
# Source vault: Your-Vault (scoped service account)
# Never put real values here — this file is committed to the repo.
# See: https://developer.1password.com/docs/cli/secret-references/

# Slack (for Slack daemon — Socket Mode bot)
SLACK_BOT_TOKEN=op://Your-Vault/Your-Slack-App/SLACK_BOT_TOKEN
SLACK_APP_TOKEN=op://Your-Vault/Your-Slack-App/SLACK_APP_TOKEN
SLACK_SIGNING_SECRET=op://Your-Vault/Your-Slack-App/SLACK_SIGNING_SECRET
SLACK_OPS_CHANNEL_ID=op://Your-Vault/Your-Slack-App/SLACK_OPS_CHANNEL_ID
SLACK_CHANNEL_ID=op://Your-Vault/Your-Slack-App/SLACK_CHANNEL_ID
SLACK_LOGS_CHANNEL_ID=op://Your-Vault/Your-Slack-App/SLACK_LOGS_CHANNEL_ID
SLACK_RESEARCH_CHANNEL_ID=op://Your-Vault/Your-Slack-App/SLACK_RESEARCH_CHANNEL_ID
SLACK_ALLOWED_USER_ID=op://Your-Vault/Your-Slack-App/SLACK_ALLOWED_USER_ID

# Email service (for notification emails, digests)
RESEND_API_KEY=op://Your-Vault/Resend/credential

# App database encryption key (if using encrypted SQLite)
YOUR_APP_DB_KEY=op://Your-Vault/Your-App-DB/encryption_key

# Claude OAuth (1-year setup-token — avoids overnight auth expiry)
CLAUDE_CODE_OAUTH_TOKEN=op://Your-Vault/Claude-OAuth-Token/credential

# OpenAI (for image generation, embeddings, etc.)
OPENAI_API_KEY=op://Your-Vault/OpenAI API/OPENAI_API_KEY

# X (Twitter) API — field names mapped from 1Password labels to script env var names
X_API_KEY=op://Your-Vault/X/Consumer Key
X_API_SECRET=op://Your-Vault/X/Consumer Secret
X_ACCESS_TOKEN=op://Your-Vault/X/Access Token
X_ACCESS_SECRET=op://Your-Vault/X/Access Token Secret
X_BEARER_TOKEN=op://Your-Vault/X/Bearer Token

# Reddit API (uncomment when configured)
# REDDIT_CLIENT_ID=op://Your-Vault/Reddit API/client_id
# REDDIT_CLIENT_SECRET=op://Your-Vault/Reddit API/client_secret
# REDDIT_USERNAME=op://Your-Vault/Reddit API/username
# REDDIT_PASSWORD=op://Your-Vault/Reddit API/password

# LinkedIn API (uncomment when configured)
# LINKEDIN_ACCESS_TOKEN=op://Your-Vault/LinkedIn API/access_token
